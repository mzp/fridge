{
  "name": "fridge",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "npm run build:ts && npm run build:css && node --env-file=.env.production dist/web/index.js",
    "start:dev": "npm run build:css && tsx src/web/index.tsx",
    "mcp": "npm run build:ts && node --env-file=.env.production dist/mcp/index.js",
    "build:ts": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "build:css": "npx @tailwindcss/cli -i public/style.css -o public/dist.css",
    "db:generate": "drizzle-kit generate",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src tests",
    "format": "biome format --write src tests",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "start:e2e": "npm run build:css && tsx --env-file=.env.test scripts/start-e2e.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@playwright/test": "^1.60.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.8.0",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "volta": {
    "node": "26.1.0"
  },
  "dependencies": {
    "@hono/mcp": "^0.2.5",
    "@hono/node-server": "^2.0.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tailwindcss/cli": "^4.3.0",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.18",
    "pino": "^10.3.1",
    "tailwindcss": "^4.3.0"
  }
}
